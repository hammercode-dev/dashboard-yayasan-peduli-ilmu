generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

model users {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email              String               @unique @db.VarChar(255)
  password           String
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  donation_evidences donation_evidences[]
  profiles           profiles?

  @@schema("public")
}

model donation_evidences {
  id               BigInt            @id @unique @default(autoincrement())
  uploaded_at      DateTime          @default(now()) @db.Timestamptz(6)
  full_name        String?
  message          String?
  evidence_url     String?
  status           String
  program_id       BigInt?
  phone_number     String?
  email            String?
  amount           Decimal?          @db.Decimal
  payment_method   String?
  description      String?
  user_id          String?           @db.Uuid
  program_donation program_donation? @relation(fields: [program_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            users?            @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model profiles {
  id         String    @id @db.Uuid
  updated_at DateTime? @db.Timestamptz(6)
  username   String?   @unique
  full_name  String?
  avatar_url String?
  address    String?
  users      users     @relation(fields: [id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model program_donation {
  id                   BigInt               @id(map: "programs_pkey") @default(autoincrement())
  created_at           DateTime             @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?            @db.Timestamptz(6)
  title                String               @unique(map: "programs_title_key")
  description          String?
  image_url            String?
  target_amount        Decimal?             @db.Decimal
  collected_amount     Decimal?             @db.Decimal
  status               String?
  starts_at            DateTime?            @default(now()) @db.Timestamptz(6)
  ends_at              DateTime?            @db.Timestamptz(6)
  location             String?
  slug                 String?              @unique
  short_description    String?
  title_en             String?
  description_en       String?
  short_description_en String?
  title_ar             String?
  description_ar       String?
  short_description_ar String?
  donation_evidences   donation_evidences[]
  program_timeline     program_timeline[]

  @@schema("public")
}

model program_timeline {
  id               BigInt            @id @default(autoincrement())
  created_at       DateTime          @default(now()) @db.Timestamptz(6)
  date             DateTime?         @db.Date
  activity         String?
  activity_en      String?
  activity_ar      String?
  cost             Decimal?          @db.Decimal
  description      String?
  program_id       BigInt?
  program_donation program_donation? @relation(fields: [program_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}
